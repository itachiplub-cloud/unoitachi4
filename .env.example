# ══════════════════════════════════════════════════════════════════════════════
# Itachi Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# ── TELEGRAM / ADMIN ──────────────────────────────────────────────────────────

# Owner Telegram user ID (bot owner, can run all admin commands)
OWNER_ID=123456789

# Comma-separated static admin Telegram user IDs
ADMIN_IDS=123456789,987654321

# Comma-separated sudo user IDs (elevated permissions)
SUDO_USERS=

# Bot username (without @)
BOT_USERNAME=your_bot_username

# ── CHANNELS ──────────────────────────────────────────────────────────────────

# Log channel ID (negative for supergroups)
LOG_CHANNEL=-1001234567890

# Update/broadcast channel ID
UPDATE_CHANNEL=

# Comma-separated force-sub channel IDs
FORCE_SUB_CHANNELS=

# ── DATABASE ──────────────────────────────────────────────────────────────────

# MongoDB connection URI (required for cloud features)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# Alias for MONGO_URL (some platforms use DATABASE_URI)
DATABASE_URI=

# Cloud database name
DATABASE_NAME=unoitachi_cloud

# SQLite database paths
DB_PATH=uno.db
CLAN_DB_PATH=uno.db
STICKERS_DB_PATH=stickers.db
BANK_DB_PATH=bank.db
DECK_DB_PATH=deck.db

# Backup settings
BACKUP_INTERVAL=1800
MAX_BACKUPS=3

# ── REDIS (optional) ──────────────────────────────────────────────────────────

REDIS_URI=
REDIS_PASSWORD=

# ── WEBHOOK / SERVER ──────────────────────────────────────────────────────────

WEBHOOK_URL=
PORT=8080

# ── AI / API KEYS ─────────────────────────────────────────────────────────────

# Groq API Key for AI reply engine (https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# OpenAI API Key (optional)
OPENAI_API_KEY=

# Google Gemini API Key (optional)
GEMINI_API_KEY=

# OpenRouter API Key (optional)
OPENROUTER_API_KEY=

# ── PYROGRAM / SESSION ────────────────────────────────────────────────────────

STRING_SESSION=

# ── LOGGER ────────────────────────────────────────────────────────────────────

# Logger group chat ID (negative for supergroups)
LOGGER_GROUP_ID=-1001234567890

# Enable/disable logging to channel
ENABLE_LOGGING=true

# ── ECONOMY / GAME SETTINGS ──────────────────────────────────────────────────

# Duel win reward amount
DUEL_REWARD=50

# Activity keyword reward cooldown (seconds, default 4 hours)
ACTIVITY_COOLDOWN=14400

# Activity keyword reward amount
ACTIVITY_REWARD=1000

# Loan interest rate (0.07 = 7%)
LOAN_INTEREST_RATE=0.07

# Loan duration in hours
LOAN_DURATION_HOURS=24

# Days before loan deduction starts
LOAN_DAILY_DEDUCTION_DAYS=3

# ── RATE LIMITS / FLOOD ──────────────────────────────────────────────────────

MAX_UPLOADS_PER_HOUR=30
MAX_UPLOADS_PER_DAY=300
UPLOAD_COOLDOWN=5

# ── CLOUD STORAGE ─────────────────────────────────────────────────────────────

# Default storage quota per user in bytes (20 GB)
DEFAULT_STORAGE_QUOTA=21474836480

# Max active share links per user
MAX_SHARE_LINKS=50

# Max file upload size in bytes (1 GB)
MAX_FILE_SIZE=1073741824

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────

# Auto-delete messages after command execution
AUTO_DELETE=false

# Comma-separated premium user IDs
PREMIUM_USERS=

# Comma-separated developer IDs
DEVELOPER_IDS=

# ── SUPPORT / LINKS ───────────────────────────────────────────────────────────

SUPPORT_CHAT=
SUPPORT_GROUP=
GITHUB_URL=https://github.com/itachiplub-cloud/unoitachi4
WEBSITE_URL=

# ── MAINTENANCE ───────────────────────────────────────────────────────────────

# Enable maintenance mode (bot rejects all commands except owner)
MAINTENANCE_MODE=false
